    "nuevaSolicitudVacaciones" : {
      "type" : "expression",
      "value" : [
        "return {",
        "    \"solicitanteId\": $data.sessionInfo.user_id,",
        "    \"fechalinicio\": $data.dataExt.fechalinicio, // <- Debe decir \"fechalinicio\" con la 'l' minúscula exacta de tu BDM",
        "    \"numeroDias\": parseInt($data.dataExt.numeroDias),",
        "    \"estaAprobado\": false",
        "};"
